# Client build-time config (copy to client/.env for local `npm start`).
# Create React App only exposes vars prefixed with REACT_APP_, and bakes them
# in at BUILD time — rebuild after changing these.

# Base URL of the API server (no trailing /api; the client adds it).
REACT_APP_API_URL=http://localhost:5000

# Base URL of the auth server, including the /auth prefix.
REACT_APP_AUTH_URL=http://localhost:5001/auth
