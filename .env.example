# Root environment for `docker compose` (copy to .env, then edit secrets).
# Compose interpolates these; sensible defaults exist in the YAML, but the JWT
# secrets below MUST be set.

# Host ports (left of the colon in the compose port mappings).
CLIENT_PORT=3000
API_PORT=5000
AUTH_PORT=5001
MONGO_PORT=27017

# Mongo database name (a local mongo container is bundled by Compose).
MONGO_DB=boredapp

# JWT secrets — generate each with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
ACCESS_TOKEN_SECRET=replace_me
REFRESH_TOKEN_SECRET=replace_me

# Where the BROWSER reaches the API/auth servers. Baked into the client image at
# build time, so these are host-facing URLs, not internal service names.
REACT_APP_API_URL=http://localhost:5000
REACT_APP_AUTH_URL=http://localhost:5001/auth
